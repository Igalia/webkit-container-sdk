[ -f "${WKDEV_SDK}/.wkdev-sdk-root" ] && source "${WKDEV_SDK}/utilities/application.sh" || { echo "Please set \${WKDEV_SDK} to point to the root of the wkdev-sdk checkout."; exit 1; }
init_application "${0}" "Updates the wkdev-sdk Git repository and containers." host-only

# Source utility script fragments
source "${WKDEV_SDK}/utilities/ansi-code-generator/ansi.sh"
source "${WKDEV_SDK}/utilities/podman.sh"

argsparse_use_option debug        "Enable debug logging for podman (useful to debug container issues)"
argsparse_use_option trace        "Enable 'xtrace' mode for this script"
argsparse_use_option force        "Always re-create matching container(s), even when already on the target version"
argsparse_describe_parameters "container-name?"

argsparse_usage_description="$(cat <<EOF
<< Purpose >>

    Updates the Git repository that holds the 'wkdev-sdk' and assists in re-creating containers, if a newer SDK version is available.
EOF
)"

process_command_line_arguments() {

    # Allow empty command line
    argsparse_allow_no_argument yes

    argsparse_parse_options "${@}"
    if [ ${#program_params[@]} -gt 1 ]; then
        _abort_ "At most one positional parameter is supported: <container-name>"
    fi

    target_container_name="${program_params[0]-}"
    argsparse_is_option_set "trace" && set -o xtrace
}

try_update_sdk_repository() {

    _log_ ""

    if [ "$(git rev-parse --abbrev-ref HEAD)" = "main" ] && [ -z "$(git status --untracked-files=no --porcelain)" ]; then
        _log_ "-> Updating Git repository 'wkdev-sdk' located in \${WKDEV_SDK}..."
        run_command git pull --rebase || _abort_ "Cannot update wkdev-sdk repository"
    else
        _log_ "-> Not updating Git repository 'wkdev-sdk' located in \${WKDEV_SDK} - there are local modifications!"
    fi
}

ask_for_confirmation() {

    local prompt="${1}"

    while true; do
        local answer=""
        read -p "${prompt}" answer

        case "${answer}" in
            [Yy]* ) return 0;;
            [Nn]* ) return 1;;
                * ) _log_ "Please answer 'y'es or 'n'o.";;
        esac
    done
}

print_available_versions() {

    local target_version="${1}"
    local latest_published="${2}"

    _log_ ""
    _log_ "-> Querying the registry for published wkdev-sdk versions..."

    if [ -z "${latest_published}" ]; then
        _log_ "   $(ansi::yellow)Warning: could not discover any published versions in the registry.$(ansi::resetForeground)"
        return
    fi

    _log_ "   Latest published version: $(ansi::bold)${latest_published}$(ansi::normal)"

    if is_version_less_than "${target_version}" "${latest_published}"; then
        _log_ "   $(ansi::yellow)Tip: a newer version is published. Run \`git pull\` in \${WKDEV_SDK} and rerun wkdev-update to adopt it.$(ansi::resetForeground)"
    fi
}

# REBUILT classifies a container whose version label matches the target but
# whose image digest doesn't (i.e. the tag was re-pushed for the same version);
# offered for upgrade alongside OUTDATED so a forced rebuild is also picked up.
update_outdated_containers() {

    local target_version="${1}"
    local sdk_repo="${2}"
    local target_image="${sdk_repo}:${target_version}"
    local target_image_id
    target_image_id="$(get_image_id_by_image_name "${target_image}")"
    [ -z "${target_image_id}" ] && _abort_ "Cannot read image id for '${target_image}' after pulling - aborting."

    local -A status_to_color=([OK]=green [OUTDATED]=red [AHEAD]=yellow [REBUILT]=red [FORCED]=yellow)
    local -a wkdev_containers=()
    local -A row_image=()
    local -A row_version=()
    local -A row_status=()
    local -a outdated=()
    local max_name_length=0

    local -a candidate_containers
    if [ -n "${target_container_name}" ]; then
        get_podman_container_status "${target_container_name}" >/dev/null \
            || _abort_ "Cannot find container '${target_container_name}'"
        candidate_containers=("${target_container_name}")
    else
        mapfile -t candidate_containers < <(get_list_of_containers)
    fi

    for container_name in "${candidate_containers[@]}"; do

        local image_with_tag current_image_id raw_version
        IFS='|' read -r image_with_tag current_image_id raw_version <<< "$(get_container_inspect_summary "${container_name}")"
        [[ "${image_with_tag}" == "${sdk_repo}:"* ]] || continue

        local current_version="$(filter_version_label "${raw_version}")"

        local status="OK"
        if argsparse_is_option_set "force"; then status="FORCED"
        elif is_version_less_than "${current_version}" "${target_version}"; then status="OUTDATED"
        elif is_version_less_than "${target_version}" "${current_version}"; then status="AHEAD"
        elif [ "${current_image_id}" != "${target_image_id}" ]; then status="REBUILT"
        fi

        case "${status}" in OUTDATED|REBUILT|FORCED) outdated+=("${container_name}");; esac

        wkdev_containers+=("${container_name}")
        row_image["${container_name}"]="${image_with_tag}"
        row_version["${container_name}"]="${current_version:-<unknown>}"
        row_status["${container_name}"]="${status}"
        [ ${#container_name} -gt ${max_name_length} ] && max_name_length=${#container_name}
    done

    if [ ${#wkdev_containers[@]} -eq 0 ]; then
        _log_ ""
        _log_ "-> No wkdev-sdk containers found - nothing to update."
        return
    fi

    _log_ ""
    _log_ "-> Found ${#wkdev_containers[@]} wkdev-sdk container(s):"
    _log_ ""

    local name
    for name in "${wkdev_containers[@]}"; do
        local status="${row_status[${name}]}"
        printf "   %-${max_name_length}s   %s   version=%-12s   $(ansi::bold)$(ansi::${status_to_color[${status}]})%-8s$(ansi::resetForeground)$(ansi::normal)\n" \
            "${name}" "${row_image[${name}]}" "${row_version[${name}]}" "${status}"
    done

    if [ ${#outdated[@]} -eq 0 ]; then
        _log_ ""
        _log_ "-> All wkdev-sdk containers are up to date."
        return
    fi

    _log_ ""
    _log_ "-> The following container(s) are eligible for upgrade to version ${target_version}:"
    _log_ "   $(ansi::bold)${outdated[*]}$(ansi::normal)"
    _log_ ""
    _log_ "   NOTE: All changes made to the local image of a recreated container are $(ansi::bold)gone$(ansi::normal)."
    _log_ ""

    for container_name in "${outdated[@]}"; do

        ask_for_confirmation "   -> Recreate $(ansi::bold)'${container_name}'$(ansi::normal) on wkdev-sdk:${target_version}? [y/n] " || continue

        local recreate_arguments=()
        recreate_arguments+=("--home" "$(get_podman_container_home_directory_on_host "${container_name}")")

        local shared_dir
        shared_dir="$(get_podman_container_shared_directory_on_host "${container_name}")"
        if [ -n "${shared_dir}" ]; then
            recreate_arguments+=("--shared-dir" "${shared_dir}")
        fi

        local init_arguments=($(get_podman_container_init_arguments "${container_name}"))
        for arg in "${init_arguments[@]}"; do
            # wkdev-create --attach passes the --exit-when-done option to .wkdev-init so that
            # podman start --attach doesn't hang forever.
            # --exit-when-done is not an option of wkdev-create however, so we need to skip it.
            if [[ "${arg}" != "--exit-when-done" ]]; then
                recreate_arguments+=("${arg}")
            fi
        done

        _log_ ""
        _log_ "       -> Stopping container..."
        run_podman_silent stop "${container_name}"

        _log_ "       -> Deleting container..."
        run_podman_silent rm "${container_name}"

        _log_ "       -> Re-creating container on wkdev-sdk:${target_version}..."
        "${WKDEV_SDK}/scripts/host-only/wkdev-create" --verbose --name "${container_name}" "${recreate_arguments[@]}"
    done
}

# Main functionality
run() {

    process_command_line_arguments "${@}"

    pushd "${WKDEV_SDK}" &>/dev/null
    try_update_sdk_repository
    popd &>/dev/null

    local target_version="$(get_sdk_version)"
    local repo_qualified="$(get_sdk_qualified_name)"

    _log_ ""
    _log_ "-> Target wkdev-sdk version (from Containerfile): $(ansi::bold)${target_version}$(ansi::normal)"

    local latest_published
    latest_published="$(list_available_sdk_versions "${repo_qualified}" | tail -n 1)"

    print_available_versions "${target_version}" "${latest_published}"

    local effective_version="${target_version}"
    if [ -n "${latest_published}" ] && is_version_less_than "${latest_published}" "${target_version}"; then
        _log_ ""
        _log_ "-> $(ansi::yellow)Note: target version '${target_version}' is not yet published to the registry.$(ansi::resetForeground)"
        _log_ "   Falling back to the latest published version: $(ansi::bold)${latest_published}$(ansi::normal)"
        effective_version="${latest_published}"
    fi

    local effective_image="${repo_qualified}:${effective_version}"

    _log_ ""
    _log_ "-> Pulling image '$(ansi::bold)${effective_image}$(ansi::normal)'..."
    run_podman pull "${effective_image}" || _abort_ "Cannot pull image '${effective_image}'"

    update_outdated_containers "${effective_version}" "${repo_qualified}"

    _log_ ""
    _log_ "-> Finished."
}

run "${@}"
